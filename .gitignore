# ============================================================
# Winnow .gitignore
# ============================================================
# Sync-aware: this file is intentionally conservative. Anything
# currently tracked stays tracked (gitignore only affects
# untracked files), so changes here only affect what *new* files
# git will pick up across your machines.
# ============================================================

# --- macOS noise ---
.DS_Store

# --- IDE / editor state (per-machine) ---
*.user
*.autosave
*.stash
.qtc_clangd/
.xcode/
.clangd

# --- CMake build (per-machine; see CMakePresets.json) ---
build/
CMakeUserPresets.json

# --- Deployment artifacts (staging / notarized / dmg / installer output) ---
out/

# --- qmake build directories (case-insensitive to match Release/release etc.) ---
[Dd]ebug/
[Rr]elease/
bin/
c/
exiv2/
UI/
x64/

# --- qmake / moc / uic / rcc generated sources ---
Makefile
Makefile.Debug
Makefile.Release
moc_*.cpp
ui_*.h
qrc_*.cpp
Winnow_resource.rc

# --- Local macOS .app bundle output (never committed) ---
Winnow.app/

# --- Compiled artifacts (Windows + cross-platform) ---
*.o
*.obj
*.lo
*.dll
*.exe
*.qm
*.db
*.ilk
*.pdb
*.res
*.idx
# PC version
# Lib/libtiff
# /Lib
# Lib/.DS_Store
# Lib/libtiff
# /Lib
*.Debug
*.Release

# --- Secrets / per-machine deploy config ---
.env
packaging/macos/config.sh
packaging/windows/config.ps1

# --- Third-party libs ---
# Headers under Lib/opencv, Lib/libheif, Lib/libde265, Lib/libtiff are
# already tracked and stay tracked. This rule prevents new build artifacts
# (object files, dylibs, CMakeFiles/, etc.) from being added automatically.
# Leading slash anchors to project root so it doesn't catch ExifTool/lib/.
/Lib/

# --- Scratch / backup copies ---
*- Copy*.cpp
*- Copy*.h
*- Copy*.txt

# Per-machine Claude Code settings (do not commit)
.claude/settings.local.json
ReleaseExtras/skyseg.onnx
ReleaseExtras/u2net.onnx
