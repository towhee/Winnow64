#include <windows.h>

/* Configured by CMake (configure_file). @WINNOW_ICON_PATH@ is the absolute path
   to images/winnow.ico for this checkout, baked in at configure time so the
   icon resolves regardless of the build/working dir and needs no hardcoded
   machine-specific path. IDI_ICON1 (the lowest icon ID) is what Explorer/the
   taskbar use as the application icon. */
IDI_ICON1	ICON	"@WINNOW_ICON_PATH@"

VS_VERSION_INFO VERSIONINFO
	FILEVERSION @WINNOW_VER_MAJOR@,@WINNOW_VER_MINOR@,@WINNOW_VER_PATCH@,@WINNOW_VER_TWEAK@
	PRODUCTVERSION @WINNOW_VER_MAJOR@,@WINNOW_VER_MINOR@,@WINNOW_VER_PATCH@,@WINNOW_VER_TWEAK@
	FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
	FILEFLAGS VS_FF_DEBUG
#else
	FILEFLAGS 0x0L
#endif
	FILEOS VOS_NT_WINDOWS32
	FILETYPE VFT_APP
	FILESUBTYPE VFT2_UNKNOWN
	BEGIN
		BLOCK "StringFileInfo"
		BEGIN
			BLOCK "040904b0"
			BEGIN
				VALUE "CompanyName", "\0"
				VALUE "FileDescription", "\0"
				VALUE "FileVersion", "@PROJECT_VERSION@\0"
				VALUE "LegalCopyright", "\0"
				VALUE "OriginalFilename", "Winnow.exe\0"
				VALUE "ProductName", "Winnow\0"
				VALUE "ProductVersion", "@PROJECT_VERSION@\0"
				VALUE "InternalName", "\0"
				VALUE "Comments", "\0"
				VALUE "LegalTrademarks", "\0"
			END
		END
		BLOCK "VarFileInfo"
		BEGIN
			VALUE "Translation", 0x0409, 1200
		END
	END
/* End of Version info */
