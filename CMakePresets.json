{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "_base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "$env{QT_DIR}",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "12.0"
      }
    },

    {
      "name": "mac-debug",
      "displayName": "macOS Debug",
      "inherits": "_base",
      "generator": "Ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "HOMEBREW_PREFIX": "/opt/homebrew"
      }
    },
    {
      "name": "mac-release",
      "displayName": "macOS Release",
      "inherits": "_base",
      "generator": "Ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "HOMEBREW_PREFIX": "/opt/homebrew"
      }
    },

    {
      "name": "mac-tsan",
      "displayName": "macOS ThreadSanitizer",
      "inherits": "_base",
      "generator": "Ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "HOMEBREW_PREFIX": "/opt/homebrew",
        "WINNOW_SANITIZE_THREAD": "ON",
        "CMAKE_MAKE_PROGRAM": "/Users/roryhill/Qt/Tools/Ninja/ninja",
        "CMAKE_C_COMPILER": "/Applications/Xcode.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/bin/clang",
        "CMAKE_CXX_COMPILER": "/Applications/Xcode.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/bin/clang++",
        "CMAKE_OBJCXX_COMPILER": "/Applications/Xcode.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/bin/clang++"
      }
    },

    {
      "name": "mac-asan",
      "displayName": "macOS AddressSanitizer",
      "inherits": "_base",
      "generator": "Ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "HOMEBREW_PREFIX": "/opt/homebrew",
        "WINNOW_SANITIZE_ADDRESS": "ON",
        "CMAKE_MAKE_PROGRAM": "/Users/roryhill/Qt/Tools/Ninja/ninja",
        "CMAKE_C_COMPILER": "/Applications/Xcode.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/bin/clang",
        "CMAKE_CXX_COMPILER": "/Applications/Xcode.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/bin/clang++",
        "CMAKE_OBJCXX_COMPILER": "/Applications/Xcode.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/bin/clang++"
      }
    },

    {
      "name": "win-debug",
      "displayName": "Windows Debug (Ninja, x64)",
      "inherits": "_base",
      "generator": "Ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "win-release",
      "displayName": "Windows Release (Ninja, x64)",
      "inherits": "_base",
      "generator": "Ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],

  "buildPresets": [
    { "name": "mac-debug",   "configurePreset": "mac-debug"   },
    { "name": "mac-release", "configurePreset": "mac-release" },
    { "name": "mac-tsan",    "configurePreset": "mac-tsan"    },
    { "name": "mac-asan",    "configurePreset": "mac-asan"    },
    { "name": "win-debug",   "configurePreset": "win-debug"   },
    { "name": "win-release", "configurePreset": "win-release" }
  ]
}
