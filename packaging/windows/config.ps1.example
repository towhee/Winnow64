# --------------------------------------------------------------------
# Per-machine Windows deployment config for Winnow.
#
# Copy this file to "config.ps1" in the same directory and edit the
# values for THIS machine. config.ps1 is git-ignored; this .example is
# committed as the template.
#
#   Copy-Item config.ps1.example config.ps1
# --------------------------------------------------------------------

# Qt install path — INFORMATIONAL ONLY. deploy.ps1 does not read this; the build
# selects Qt via the QT_DIR environment variable (CMakePresets CMAKE_PREFIX_PATH)
# or the VS/Qt Creator kit, and windeployqt runs as a CMake POST_BUILD step that
# tracks the linked Qt. Kept here for reference / future use.
$QtDir = "C:\Qt\6.9.2\msvc2022_64"

# Inno Setup compiler (iscc.exe).
$InnoSetupCompiler = "C:\Program Files (x86)\Inno Setup 6\ISCC.exe"

# --- Code signing (optional; leave SignEnabled = $false to skip) -------------
# Requires an OV/EV code-signing certificate. Without it the installer is
# unsigned (users get a SmartScreen warning).
$SignEnabled = $false
$SignToolPath = "C:\Program Files (x86)\Windows Kits\10\bin\10.0.22621.0\x64\signtool.exe"
# Either a PFX path + password, or a cert subject name already in the store.
$SignCertSubject = "Robert Hill"
$SignTimestampUrl = "http://timestamp.digicert.com"

# --- Distribution upload (optional; leave UploadEnabled = $false to skip) -----
$UploadEnabled = $false
# Uses WinSCP or scp; target host path for the Setup.exe.
$UploadTarget = "root@165.227.46.158:/var/www/html/winnow_win/test"
$UploadSshKey = "$env:USERPROFILE\.ssh\winnow_deploy.ppk"
