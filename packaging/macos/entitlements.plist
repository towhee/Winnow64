<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
	"http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

	<!-- Disable sandbox (required for desktop macOS apps) -->
	<key>com.apple.security.app-sandbox</key>
	<false/>

	<!-- Hardened Runtime: plugin/dylib loading -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>

	<!-- OpenCV + FFmpeg + ONNX: dynamic code, SIMD, JIT -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	<key>com.apple.security.cs.allow-executable-memory</key>
	<true/>

	<!-- Allow DYLD variables (needed for ExifTool child execution) -->
	<key>com.apple.security.cs.allow-dyld-environment-variables</key>
	<true/>

	<!-- Allow user-selected file access -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>

	<!-- Networking: Qt uses networking APIs -->
	<key>com.apple.security.network.client</key>
	<true/>

</dict>
</plist>
